NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Database
DATABASE_URL=postgresql://deadhand:deadhand@localhost:5432/deadhand?schema=public

# Session / auth
JWT_SECRET=replace-me
JWT_EXPIRY_HOURS=24
AUTH_CHALLENGE_TTL_SECONDS=300

# Optional cache / rate limit store
REDIS_URL=

# Chain
BNB_CHAIN_ID=97
BNB_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BSC_SCAN_BASE_URL=https://testnet.bscscan.com

# AI provider
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=

# Adapter config
# PancakeSwap defaults to the official BNB testnet v3 SwapRouter in runtime when chainId=97.
# Set PANCAKESWAP_ROUTER_ADDRESS only if you want to override that default.
# Four.Meme remains explicit-only until trustworthy router/factory details are confirmed.
FOUR_MEME_FACTORY_ADDRESS=
FOUR_MEME_ROUTER_ADDRESS=
PANCAKESWAP_ROUTER_ADDRESS=

# Demo wiring
DEMO_WALLET_ADDRESS=
DEMO_WALLET_PRIVATE_KEY=
