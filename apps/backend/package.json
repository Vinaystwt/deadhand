{
  "name": "@deadhand/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "test": "NODE_ENV=test node --import tsx --test tests/**/*.test.ts",
    "test:unit": "NODE_ENV=test node --import tsx --test tests/unit/**/*.test.ts",
    "test:integration": "NODE_ENV=test node --import tsx --test tests/integration/**/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "seed:demo": "tsx src/scripts/seedDemo.ts",
    "demo:gauntlet": "node --import tsx src/scripts/demoGauntlet.ts",
    "smoke:anthropic": "tsx src/scripts/smokeAnthropic.ts",
    "smoke:external": "tsx src/scripts/smokeExternalWiring.ts",
    "check:readiness": "tsx src/scripts/checkRuntimeReadiness.ts",
    "verify:live": "tsx src/scripts/verifyLiveExecution.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@deadhand/types": "0.1.0",
    "@prisma/client": "^5.12.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.0.0",
    "viem": "^2.21.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "node-mocks-http": "^1.17.2",
    "prisma": "^5.12.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
