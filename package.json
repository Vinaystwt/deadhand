{
  "name": "deadhand",
  "version": "0.1.0",
  "private": true,
  "description": "Deadhand backend-first policy wallet for AI-assisted BNB/Four.Meme execution.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm --prefix apps/backend run dev",
    "dev:backend": "npm --prefix apps/backend run dev",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm --prefix apps/backend run test:unit",
    "test:integration": "npm --prefix apps/backend run test:integration",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm --prefix apps/backend run prisma:generate",
    "prisma:migrate:dev": "npm --prefix apps/backend run prisma:migrate:dev",
    "seed:demo": "npm --prefix apps/backend run seed:demo",
    "demo:gauntlet": "npm --prefix apps/backend run demo:gauntlet",
    "smoke:anthropic": "npm --prefix apps/backend run smoke:anthropic",
    "smoke:external": "npm --prefix apps/backend run smoke:external"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
